# Copy to .env on the server before running docker compose.

SITE_DOMAIN=example.com

OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT=20
OPENAI_MAX_TOKENS=320
OPENAI_TEMPERATURE=0.25
OPENAI_MAX_RETRIES=0

POSTGRES_DB=jinse
POSTGRES_USER=jinse
POSTGRES_PASSWORD=change-this-password

JINSE_CORS_ORIGIN=*
JINSE_FALLBACK_STREAM_DELAY=0.08

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
