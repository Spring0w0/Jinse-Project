# Copy to .env on the server before running docker compose.
#
# Generate a strong DB password:  openssl rand -base64 24

# --- AI / LLM ---
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4.1-mini
# For non-OpenAI providers (e.g. DeepSeek, Qwen), set the base URL:
OPENAI_BASE_URL=
OPENAI_TIMEOUT=20
OPENAI_MAX_TOKENS=320
OPENAI_TEMPERATURE=0.25
OPENAI_MAX_RETRIES=0

# --- PostgreSQL ---
POSTGRES_DB=jinse
POSTGRES_USER=jinse
POSTGRES_PASSWORD=change-this-password

# --- CORS (set to your actual domain in production, e.g. http://your-domain:81) ---
JINSE_CORS_ORIGIN=*

# --- Fallback streaming (used when OPENAI_API_KEY is empty) ---
JINSE_FALLBACK_STREAM_DELAY=0.08

# --- Gunicorn tuning ---
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
