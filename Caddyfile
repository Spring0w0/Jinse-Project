# Jinse — standalone on port 81, completely isolated from other web services.
# Access via: http://your-server-ip:81  or  http://your-domain:81

:81 {
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:5001
	}

	root * /srv
	try_files {path} /index.html
	file_server

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
